# ═══════════════════════════════════════════════════════════════
#  VengaiCode — Environment Variables
#  Vengai (வேங்கை) = Tiger in Tamil 🐯
#
#  SETUP INSTRUCTIONS:
#  1. Copy this file: cp .env.example .env
#  2. Fill in your values below
#  3. NEVER commit .env to Git — it is in .gitignore
#
#  All services with ← FREE mean free tier available
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────
#  App Configuration
# ───────────────────────────────────────────────
APP_NAME=VengaiCode
APP_VERSION=1.0.0
ENVIRONMENT=development
# Options: development | production
DEBUG=true

# ───────────────────────────────────────────────
#  AI Configuration
# ───────────────────────────────────────────────

# Groq API — FREE tier: 14,400 requests/day
# Sign up: https://console.groq.com
# Used as cloud AI fallback when local Ollama is slow
GROQ_API_KEY=

# Ollama — runs locally on user's machine (FREE always)
# Desktop app connects to this automatically
OLLAMA_HOST=http://localhost:11434

# ───────────────────────────────────────────────
#  Database — Supabase PostgreSQL
#  FREE tier: 500MB PostgreSQL
#  Sign up: https://supabase.com
# ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Local development PostgreSQL (from docker-compose)
DATABASE_URL=postgresql://vengaicode_user:vengaicode_pass_dev@localhost:5432/vengaicode

# ───────────────────────────────────────────────
#  Redis Cache — Upstash
#  FREE tier: 10,000 requests/day
#  Sign up: https://upstash.com
# ───────────────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Local development Redis (from docker-compose)
REDIS_URL=redis://:vengaicode_redis_dev@localhost:6379/0
REDIS_PASSWORD=vengaicode_redis_dev

# ───────────────────────────────────────────────
#  File Storage — Cloudflare R2
#  FREE tier: 10GB storage, zero egress fees
#  Sign up: https://cloudflare.com
# ───────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET=
CLOUDFLARE_R2_BUCKET=vengaicode-files
CLOUDFLARE_R2_ENDPOINT=
# Format: https://<account_id>.r2.cloudflarestorage.com

# ───────────────────────────────────────────────
#  Payment Gateway — Razorpay
#  Sign up: https://razorpay.com (Already have account)
#  Supports: GPay, PhonePe, Paytm, UPI, Cards, NetBanking
# ───────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Note: Use test keys (rzp_test_...) for development
# Switch to live keys (rzp_live_...) for production

# ───────────────────────────────────────────────
#  Identity Verification — Digio
#  Used for: Aadhaar eKYC + PAN Card verification
#  Sign up: https://digio.in
# ───────────────────────────────────────────────
DIGIO_API_KEY=
DIGIO_API_SECRET=
DIGIO_BASE_URL=https://ext.digio.in:444

# ───────────────────────────────────────────────
#  SMS Service — MSG91
#  FREE tier available for India
#  Sign up: https://msg91.com
#  Used for: OTP delivery to Indian mobile numbers
# ───────────────────────────────────────────────
MSG91_API_KEY=
MSG91_SENDER_ID=VENGAI
MSG91_TEMPLATE_ID=
# OTP template ID from MSG91 dashboard

# ───────────────────────────────────────────────
#  Email Service — Resend
#  FREE tier: 3,000 emails/month
#  Sign up: https://resend.com
# ───────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=support@vengaicode.com
EMAIL_FROM_NAME=VengaiCode

# ───────────────────────────────────────────────
#  Security Keys
#  Generate JWT_SECRET: openssl rand -hex 32
#  Generate ENCRYPTION_KEY: openssl rand -hex 32
# ───────────────────────────────────────────────
JWT_SECRET=
# IMPORTANT: Generate a strong random secret — never use default
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

ENCRYPTION_KEY=
# IMPORTANT: Generate a strong random key — never use default

# RSA Keys for Licence System
# Generate: openssl genrsa -out private.pem 2048
# Extract public: openssl rsa -in private.pem -pubout -out public.pem
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# ───────────────────────────────────────────────
#  Error Tracking — Sentry
#  FREE tier: 5,000 errors/month
#  Sign up: https://sentry.io
# ───────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ───────────────────────────────────────────────
#  Search — MeiliSearch
#  FREE: self-hosted via docker-compose
#  Local development URL below
# ───────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=vengaicode_meili_dev_key
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_KEY=vengaicode_meili_dev_key

# ───────────────────────────────────────────────
#  Frontend Public Variables (Next.js Marketplace)
#  These are exposed to the browser — no secrets!
# ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Use test key here: rzp_test_...

# ───────────────────────────────────────────────
#  Analytics — PostHog
#  FREE: self-hosted (via docker-compose later)
#  Or FREE cloud tier: https://posthog.com
# ───────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ───────────────────────────────────────────────
#  VengaiCode Admin Config
# ───────────────────────────────────────────────
ADMIN_SECRET_KEY=
# Used for hidden admin panel access — generate strong random string
ADMIN_EMAIL=
# Your email address for admin notifications

# ───────────────────────────────────────────────
#  Commission Config
# ───────────────────────────────────────────────
COMMISSION_MARKETPLACE_PERCENT=10
# 10% commission on VengaiCode marketplace sales
COMMISSION_EXTERNAL_PERCENT=25
# 25% commission on external platform sales
COMMISSION_TEMPLATE_PERCENT=10
# 10% commission on community template sales

# ───────────────────────────────────────────────
#  Baby Tiger Stamp Config 🐯
# ───────────────────────────────────────────────
TIGER_STAMP_ENABLED=true
TIGER_STAMP_CRYPTOGRAPHIC_KEY=
# Generate: openssl rand -hex 64
# This key signs all Baby Tiger stamps — keep it secret!

# ───────────────────────────────────────────────
#  Local Docker Services (auto-filled by docker-compose)
#  Only needed if running services manually
# ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vengaicode
POSTGRES_USER=vengaicode_user
POSTGRES_PASSWORD=vengaicode_pass_dev
